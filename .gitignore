# graphify scratch files (any graphify-out/ folder, at any depth)
**/graphify-out/.graphify_*
**/graphify-out/cache/
**/graphify-out/.needs_update

# graphify scratch files at repo ROOT (regenerated locally; transient)
/.graphify_*

# Python bytecode cache
__pycache__/
*.pyc

# Graphify output at REPO ROOT only (regenerated locally; transient)
# — but graphify-out/ committed under docs/handoff/ is intentional
# (the persistent handoff graph). Use leading slash for root-only match.
/graphify-out/

# Tool-builder swarm worker scratch state (do not commit)
.claude-flow/
ruvector.db

# Local npm install — Vercel reinstalls from package-lock.json on every
# deploy; no need to commit the resolved tree.
node_modules/
